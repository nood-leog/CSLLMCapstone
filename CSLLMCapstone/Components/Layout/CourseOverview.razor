@using CSLLMCapstone.Models 
@using CSLLMCapstone.Services
@inject IJSRuntime JSRuntime
@inject DbService Db
@inject NavigationManager NavManager
@inject UserSessionService UserSession

<!--CourseID, CourseTitle, CourseDesc, and OnClose input params-->
@code {
    [Parameter] public int CourseID { get; set; }
    [Parameter] public string? CourseTitle { get; set; }
    [Parameter] public string? CourseDesc { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    // List of topics for the selected course
    private List<Topic> topics = new();
    private bool isLoading = true;

    // Fetch topics on component initialization
    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        topics = await Db.GetTopicsByCourseIDAsync(CourseID);
        isLoading = false;
    }
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<!--Course Modal-->
<div class="modal" id="courseModal" style="display: flex !important; align-items: center; justify-content: center;">
    <div class="modal-content">
        <div class="modal-header">
            <h2><i class="fas fa-cat"></i> CS Study Cat</h2>
            <a class="close-modal" @onclick="OnClose">&times;</a>
        </div>

        <div class="modal-body">
            <!--Left Column - Quiz, Flashcards, and Tutor Mode Buttons-->
            <div class="left-column">
                <a class="study-button" @onclick='() => HandleInstanceClick(InstanceType.Quiz)'>
                    <i class="fas fa-question-circle"></i>
                    <div class="button-label">
                        <div>Quiz</div>
                        <span>Test your knowledge</span>
                    </div>
                </a>
                
                <a class="study-button" @onclick='() => HandleInstanceClick(InstanceType.Flash)'>
                    <i class="fas fa-sticky-note"></i>
                    <div class="button-label">
                        <div>Flashcards</div>
                        <span>Learn terms & concepts</span>
                    </div>
                </a>

                <a class="study-button" @onclick='() => HandleInstanceClick(InstanceType.Tutor)'>
                    <i class="fas fa-chalkboard-teacher"></i>
                    <div class="button-label">
                        <div>Tutor</div>
                        <span>Interactive AI tutoring</span>
                    </div>
                </a>
            </div>

            <!--Right Column - Course Info-->
            <div class="right-column">
                <div class="course-title-section">
                    <div class="course-title-icon">CS</div>
                    <div class="course-title-text">
                        <h2>@CourseID</h2>
                        <p>@CourseTitle</p>
                    </div>
                </div>

                <div class="course-description">
                    <h3>Course Description</h3>
                    <p>@CourseDesc</p>
                </div>
            </div>

            <!--Dynamic Topics Section-->
            <div class="topics-section">
                <h3>Topics</h3>
                <div>
                    @if (isLoading)
                    {
                        <p>Loading topics...</p>
                    }
                    else if (topics == null || !topics.Any())
                    {
                        <p>No topics found for this course.</p>
                    }
                    else
                    {
                        @foreach (var topic in topics)
                        {
                            <a class="topic-row" @onclick='() => HandleTopicClick(topic)'>
                                <div class="topic-name">@topic.Name</div>
                                <div class="topic-arrow"><i class="fas fa-chevron-right"></i></div>
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!--Display Topic Overview if topic is clicked-->
    @if (isTopicClicked)
    {
        <TopicOverview Topic="@topic" CourseID="@CourseID" OnClose="() => isTopicClicked = false" />
    }
</div>

<!--HandleTopicClick Logic-->
@code {
    private bool isTopicClicked = false;
    // topicName to hold clicked topic name
    private Topic? topic;

    private void HandleTopicClick(Topic selectedTopic)
    {
        isTopicClicked = true; // flip flag
        topic = selectedTopic; // set topic
    }
}

<!--HandleInstanceClick Logic-->
@code {
    private async Task HandleInstanceClick(InstanceType type)
    {
        // Check if user is logged in
        // if (!UserSession.IsLoggedIn)
        // {
        //     Console.WriteLine("User not logged in");
        //     NavManager.NavigateTo("/");
        //     return;
        // }

        // Check CourseId number
        if (CourseID <= 0)
        {
            Console.WriteLine("Invalid CourseID");
            return;
        }


        try
        {
            // Create new instance
            var newInstance = new Instance
            {
                UserId = int.Parse(await JSRuntime.InvokeAsync<string>("localStorage.getItem", "UserId")),
                Type = type,
                Data = "{}" // Initialize with empty JSON
            };

            // Save to database
            await Db.SaveInstanceAsync(newInstance);

            // Navigate to the appropriate route with the instance ID
            string route = type switch
            {
                InstanceType.Quiz => $"/dashboard/quiz/{newInstance.InstanceId}",
                InstanceType.Flash => $"/dashboard/flash/{newInstance.InstanceId}/{CourseID}",
                InstanceType.Tutor => $"/dashboard/tutor/{newInstance.InstanceId}",
                _ => "/dashboard"
            };

            NavManager.NavigateTo(route);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating instance: {ex.Message}");
        }
    }
}