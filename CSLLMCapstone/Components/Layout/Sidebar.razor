@using CSLLMCapstone.Models
@using CSLLMCapstone.Services
@rendermode InteractiveServer
@inject DbService Db
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

<!--FName and LName input params-->
@code {
    [Parameter] public string? FName { get; set; }
    [Parameter] public string? LName { get; set; }

    // Computed property for the initials
    private string UserInitials =>
        $"{(string.IsNullOrEmpty(FName) ? "" : FName[0].ToString())}{(string.IsNullOrEmpty(LName) ? "" : LName[0].ToString())}".ToUpper();

    // Fallback if both are empty
    private string DisplayInitials => string.IsNullOrWhiteSpace(UserInitials) ? "SC" : UserInitials;

    // Helper to map Enum types to FontAwesome icons
    private string GetInstanceIcon(InstanceType type) => type switch
    {
        InstanceType.Tutor => "fa-chalkboard-teacher",
        InstanceType.Flash => "fa-sticky-note",
        InstanceType.Quiz => "fa-question-circle",
        _ => "fa-history"
    };
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<!--Loading Screen-->
@if (isLoading)
{
    <div class="loading-screen">
        <p>Loading your instance history...</p>
    </div>
}

<div>
    <!--Sidebar-->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <i class="fas"></i>
            <h1>CS Study Cat</h1>
        </div>

        <div class="sidebar-user-section">
            <!--Dynamic User Details-->
            <div class="sidebar-user-info">
                <div class="sidebar-user-avatar">@DisplayInitials</div>
                <div class="sidebar-user-details">
                    <h3>@FName @LName</h3>
                </div>
            </div>

            <!--DYNAMIC - Instance History-->
            <div class="sidebar-instance-section">
                <h4>Instance History</h4>
                @if (instances != null && instances.Any())
                {
                    @foreach (var instance in instances)
                    {
                        <div class="sidebar-instance-container">
                            <a class="sidebar-instance-item" @onclick='() => HandleInstanceClick(instance)'>
                                <div class="sidebar-instance-icon">
                                    <i class="fas @GetInstanceIcon(instance.Type)"></i>
                                </div>
                                <div class="sidebar-instance-info">
                                    <h5>@instance.Type</h5>
                                    <p>CS @instance.CourseId @instance.CourseTitle</p>
                                </div>
                            </a>
                            <div class="instance-actions">
                                <button class="favorite-button @(instance.IsFavorite ? "is-favorite" : "")"
                                        @onclick='() => HandleFavoriteClick(instance)' @onclick:stopPropagation="true">
                                    <i class="@(instance.IsFavorite ? "fas fa-star" : "far fa-star")"></i>
                                </button>
                                <button class="delete-button"
                                        @onclick='() => HandleDeleteClick(instance)' @onclick:stopPropagation="true">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                }
                else if (!isLoading)
                {
                    <p class="no-history-text">No history found</p>
                }
            </div>
        </div>
    </div>
</div>

@code {
    // List of instances - to be fetched from DB
    private List<Instance> instances = new List<Instance>();

    // Loading state for dashboard
    private bool isLoading = true;

    // Checking if user is authenticated
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 1. Check local storage for the UserID
            var userId = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "UserId");

            if (string.IsNullOrEmpty(userId))
            {
                // 2. If no user found, boot them to login
                NavManager.NavigateTo("/");
            }
            else
            {
                // 3. User is valid, fetch the instances show the UI
                instances = await Db.GetUserHistoryAsync(int.Parse(userId));
                isLoading = false;
                StateHasChanged(); // Force a re-render now that we have data
            }
        }
    }
}

<!--HandleInstanceClick Logic for the instance history-->
@code {
    private async Task HandleInstanceClick(Instance instance)
    {
        try
        {
            // Navigate to the appropriate route with the instance ID
            string route = instance.Type switch
            {
                InstanceType.Quiz => $"/dashboard/quiz/{instance.InstanceId}",
                InstanceType.Flash => $"/dashboard/flash/{instance.InstanceId}",
                InstanceType.Tutor => $"/dashboard/tutor/{instance.InstanceId}",
                _ => "/dashboard"
            };

            NavManager.NavigateTo(route);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating instance: {ex.Message}");
        }
    }
}

<!--HandleFavoriteClick Logic for the instance history-->
@code {
    private async Task HandleFavoriteClick(Instance instance)
    {
        try
        {
            // Toggle the favorite status
            instance.IsFavorite = !instance.IsFavorite;
            // Update the database with the new favorite status
            await Db.UpdateInstanceFavoriteStatusAsync(instance.InstanceId, instance.IsFavorite);
            StateHasChanged(); // Force a re-render to reflect changes
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating favorite status: {ex.Message}");
        }
    }
}

<!--HandleDeleteClick Logic for the instance history-->
@code {
    private async Task HandleDeleteClick(Instance instance)
    {
        try
        {
            // prompt the user for confirmation before deleting (UPDATE UI LATER)
            bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete this {instance.Type} instance?");
            if (!confirmed)
            {
                return; // User canceled the deletion
            }
            // Delete the instance from the database
            await Db.DeleteInstanceAsync(instance.InstanceId);
            NavManager.NavigateTo("/dashboard"); // Refresh the dashboard to update instance history
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting instance: {ex.Message}");
        }
    }
}