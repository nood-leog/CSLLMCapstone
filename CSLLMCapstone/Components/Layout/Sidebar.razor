<!--FName and LName input params-->
@code {
    [Parameter] public string? FName { get; set; }
    [Parameter] public string? LName { get; set; }

    // Computed property for the initials
    private string UserInitials =>
        $"{(string.IsNullOrEmpty(FName) ? "" : FName[0].ToString())}{(string.IsNullOrEmpty(LName) ? "" : LName[0].ToString())}".ToUpper();

    // Fallback if both are empty
    private string DisplayInitials => string.IsNullOrWhiteSpace(UserInitials) ? "SC" : UserInitials;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div>
    <!--Sidebar-->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <i class="fas"></i>
            <h1>CS Study Cat</h1>
        </div>

        <div class="sidebar-user-section">
            <!--Dynamic User Details-->
            <div class="sidebar-user-info">
                <div class="sidebar-user-avatar">@DisplayInitials</div>
                <div class="sidebar-user-details">
                    <h3>@FName @LName</h3>
                </div>
            </div>

            <!--HARDCODED - Instance History-->
            <div class="sidebar-instance-section">
                <h4>Instance History</h4>
                <a href="#tutorModal" class="sidebar-instance-item">
                    <div class="sidebar-instance-icon">
                        <i class="fas fa-chalkboard-teacher"></i>
                    </div>
                    <div class="sidebar-instance-info">
                        <h5>Tutor Session</h5>
                        <p>CS 111 - OOP</p>
                    </div>
                </a>
                <a href="#flashcardsModal" class="sidebar-instance-item">
                    <div class="sidebar-instance-icon">
                        <i class="fas fa-sticky-note"></i>
                    </div>
                    <div class="sidebar-instance-info">
                        <h5>Flashcards</h5>
                        <p>Algorithms</p>
                    </div>
                </a>
                <a href="#quizModal" class="sidebar-instance-item">
                    <div class="sidebar-instance-icon">
                        <i class="fas fa-question-circle"></i>
                    </div>
                    <div class="sidebar-instance-info">
                        <h5>Quiz</h5>
                        <p>Data Structures</p>
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>