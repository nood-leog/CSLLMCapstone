@using CSLLMCapstone.Models 
@using CSLLMCapstone.Services
@using System.Text.Json
@inject IJSRuntime JSRuntime
@inject DbService Db
@inject NavigationManager NavManager
@inject UserSessionService UserSession

<!--Topic, CourseID, and OnClose input params-->
@code {
    [Parameter] public Topic? Topic { get; set; }
    [Parameter] public int CourseID { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<!--Topic Modal-->
<div class="modal" id="topicModal" style="display: flex !important; align-items: center; justify-content: center;">
    <div class="topic-modal-content">
        <div class="topic-modal-header">
            <h2><i class="fas fa-cat"></i> CS Study Cat</h2>
            <a class="close-modal" @onclick="OnClose">&times;</a>
        </div>

        <div class="topic-modal-body">
            <!--Left Column - Quiz, Flashcards, and Tutor Mode Buttons-->
            <div class="topic-left-column">
                <a class="topic-study-button" @onclick='() => HandleInstanceClick(InstanceType.Quiz)'>
                    <i class="fas fa-question-circle"></i>
                    <div class="topic-button-label">
                        <div>Quiz</div>
                        <span>Test your knowledge</span>
                    </div>
                </a>

                <a class="topic-study-button" @onclick='() => HandleInstanceClick(InstanceType.Flash)'>
                    <i class="fas fa-sticky-note"></i>
                    <div class="topic-button-label">
                        <div>Flashcards</div>
                        <span>Learn terms & concepts</span>
                    </div>
                </a>

                <a class="topic-study-button" @onclick='() => HandleInstanceClick(InstanceType.Tutor)'>
                    <i class="fas fa-chalkboard-teacher"></i>
                    <div class="topic-button-label">
                        <div>Tutor</div>
                        <span>Interactive AI tutoring</span>
                    </div>
                </a>
            </div>

            <!--Right Column - Topic Info-->
            <div class="topic-right-column">
                <div class="topic-title-section">
                    <div class="topic-title-icon">CS</div>
                    <div class="topic-title-text">
                        <h2>@CourseID / @(Topic?.Name ?? "Unknown")</h2>
                    </div>
                </div>

                <div class="topic-description">
                    <h3>Topic Description</h3>
                    <p>@(Topic?.Name ?? "No description available.")</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private async Task HandleInstanceClick(InstanceType type)
    {
        // Check if user is logged in
        // if (!UserSession.IsLoggedIn)
        // {
        //     Console.WriteLine("User not logged in");
        //     NavManager.NavigateTo("/");
        //     return;
        // }

        // Load inforation to store a topic if clicked
        var topInfo = new
        {
            courseId = CourseID,
            topicId = Topic?.TopicId,
            topicName = Topic?.Name

        };

        try
        {
            // Create new instance with topic information
            var newInstance = new Instance
            {
                UserId = int.Parse(await JSRuntime.InvokeAsync<string>("localStorage.getItem", "UserId")),
                Type = type,
                Data = JsonSerializer.Serialize(topInfo)
                //Data = $"{{\"courseId\":{CourseID},\"topicId\":{Topic?.TopicId},\"topicName\":\"{Topic?.Name}\"}}"
            };


            // Save to database
            await Db.SaveInstanceAsync(newInstance);

            // Navigate to the appropriate route with the instance ID
            string route = type switch
            {
                InstanceType.Quiz => $"/dashboard/quiz/{newInstance.InstanceId}/{CourseID}",
                InstanceType.Flash => $"/dashboard/flash/{newInstance.InstanceId}/{CourseID}",
                InstanceType.Tutor => $"/dashboard/tutor/{newInstance.InstanceId}",
                _ => "/dashboard"
            };

            NavManager.NavigateTo(route);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating instance: {ex.Message}");
        }
    }
}