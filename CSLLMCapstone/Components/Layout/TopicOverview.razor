@using CSLLMCapstone.Models
@using CSLLMCapstone.Services

<!--TopicName, CourseID, and OnClose input params-->
@code {
    [Parameter] public Topic? Topic { get; set; }
    [Parameter] public int? CourseID { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<!--Topic Modal-->
<div class="modal" id="topicModal" style="display: flex !important; align-items: center; justify-content: center;">
    <div class="topic-modal-content">
        <div class="topic-modal-header">
            <h2><i class="fas fa-cat"></i> CS Study Cat</h2>
            <a class="close-modal" @onclick="OnClose">&times;</a>
        </div>

        <div class="topic-modal-body">
            <!--Left Column - Quiz, Flashcards, and Tutor Mode Buttons-->
            <div class="topic-left-column">
                <a href="#quizModal" class="topic-study-button">
                    <i class="fas fa-question-circle"></i>
                    <div class="topic-button-label">
                        <div>Quiz</div>
                        <span>Test your knowledge</span>
                    </div>
                </a>

                <a href="#flashcardsModal" class="topic-study-button">
                    <i class="fas fa-sticky-note"></i>
                    <div class="topic-button-label">
                        <div>Flashcards</div>
                        <span>Learn terms & concepts</span>
                    </div>
                </a>

                <a href="#tutorModal" class="topic-study-button">
                    <i class="fas fa-chalkboard-teacher"></i>
                    <div class="topic-button-label">
                        <div>Tutor</div>
                        <span>Interactive AI tutoring</span>
                    </div>
                </a>
            </div>

            <!--Right Column - Topic Info-->
            <div class="topic-right-column">
                <div class="topic-title-section">
                    <div class="topic-title-icon">CS</div>
                    <div class="topic-title-text">
                        <h2>@CourseID/@(Topic?.Name ?? "Loading Topic...")</h2>
                    </div>
                </div>
                <!--Dynamic topic description-->
                <div class="topic-description">
                    <h3>Topic Description</h3>
                    <p>
                        @if (Topic != null && !string.IsNullOrWhiteSpace(Topic.TopicDesc))
                        {
                            @Topic.TopicDesc
                        }
                        else
                        {
                            <span class="text-muted italic">No description available for this topic.</span>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>