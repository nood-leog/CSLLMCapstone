@page "/dashboard/tutor/{instanceId}"
@using CSLLMCapstone.Services
@using CSLLMCapstone.Models
@rendermode InteractiveServer
@inject DbService Db
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<PageTitle>CS Study Cat - Tutor Mode</PageTitle>

<div class="dashboard-body">
    <!--Sidebar component-->
    @if (user != null)
    {
        <Sidebar FName="@(user.FName ?? "")" LName="@(user.LName ?? "")" />
    }
    else
    {
        <!--Pass Study Cat if user not found-->
        <Sidebar FName="Study" LName="Cat" />
    }
    
    <!--Main Content-->
    <div class="main-content">
        <!--Top Bar-->
        <div class="top-bar">
            <label for="sidebar-toggle" class="mobile-menu-btn">
                <i class="fas fa-bars"></i>
            </label>

            <div class="page-title">
                <h2><i class="fas fa-chalkboard-teacher"></i> Tutor Mode</h2>
                @if (!string.IsNullOrEmpty(InstanceId))
                {
                    <span class="instance-id-badge">Instance: @InstanceId</span>
                }
            </div>
            
            <a href="/dashboard" class="close-modal">&times;</a>
        </div>

        <!--Tutor Content - HARDCODED, MUST UPDATE W/ LLM INTEGRATION-->
        <div class="study-session-body">
            <div class="tutor-container">
                <!--Tutor Header-->
                <div class="tutor-header">
                    <div class="flashcards-title">
                        @if (instance != null)
                        {
                            <span>CS @instance.CourseId @instance.CourseTitle</span>
                        }
                        else
                        {
                            <span>Loading Course Details...</span>
                        }
                    </div>
                </div>
                    
                <div class="tutor-content">
                    <div class="tutor-chat-container">
                        <div class="tutor-message bot">
                            <div class="tutor-avatar">
                                <i class="fas fa-robot"></i>
                            </div>
                            <div class="tutor-message-content">
                                Lorem ipsum dolor sit amet consectetur adipiscing elit. Quisque faucibus ex sapien vitae pellentesque sem placerat.
                            </div>
                        </div>
                        <div class="tutor-message user">
                            <div class="tutor-avatar">
                                <i class="fas fa-user"></i>
                            </div>
                            <div class="tutor-message-content">
                                In id cursus mi pretium tellus duis convallis?
                            </div>
                        </div>
                    </div>
                        
                    <div class="tutor-input-container">
                        <input type="text" class="tutor-input" placeholder="Ask anything about computer science..." value="Lorem ipsum dolor sit amet?">
                        <button class="tutor-send-button">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!--Footer-->
        <div class="footer">
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? InstanceId { get; set; }

    // delcare instance so HTML can access course info for quiz header
    private Instance? instance;

    protected override async Task OnInitializedAsync()
    {
        // Load instance data here if needed
        if (!string.IsNullOrEmpty(InstanceId))
        {
            // get the instance from instance id
            instance = await Db.GetInstanceByIdAsync(InstanceId);

            if (instance != null)
            {
                // call llm service to generate tutor content based on instance data
            }
        }
    }
}

@code {
    // User details - to be fetched from DB
    private User? user;

    // Checking if user is authenticated
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 1. Check local storage for the UserID
            var userId = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "UserId");

            if (string.IsNullOrEmpty(userId))
            {
                // 2. If no user found, boot them to login
                NavManager.NavigateTo("/");
            }
            else
            {
                // 3. User is valid, fetch the user details and show the UI
                user = await Db.GetUserByIdAsync(int.Parse(userId));
                StateHasChanged(); // Force a re-render now that we have data
            }
        }
    }
}