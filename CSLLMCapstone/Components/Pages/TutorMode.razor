@page "/dashboard/tutor/{instanceId}"
@using CSLLMCapstone.Services
@using CSLLMCapstone.Models
@rendermode InteractiveServer
@inject DbService Db
@inject LLMService llm
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<PageTitle>CS Study Cat - Tutor Mode</PageTitle>

<div class="dashboard-body">
    <!--Sidebar component-->
    @if (user != null)
    {
        <Sidebar FName="@(user.FName ?? "")" LName="@(user.LName ?? "")" />
    }
    else
    {
        <!--Pass Study Cat if user not found-->
        <Sidebar FName="Study" LName="Cat" />
    }
    
    <!--Main Content-->
    <div class="main-content">
        <!--Top Bar-->
        <div class="top-bar">
            <label for="sidebar-toggle" class="mobile-menu-btn">
                <i class="fas fa-bars"></i>
            </label>

            <div class="page-title">
                <h2><i class="fas fa-chalkboard-teacher"></i> Tutor Mode</h2>
                @if (!string.IsNullOrEmpty(InstanceId))
                {
                    <span class="instance-id-badge">Instance: @InstanceId</span>
                }
            </div>
            
            <a href="/dashboard" class="close-modal">&times;</a>
        </div>

        <!--Tutor Content - Dynamic with LLM-->
        <div class="study-session-body">
            <div class="tutor-container">
                <!--Tutor Header-->
                <div class="tutor-header">
                    <div class="flashcards-title">
                        @if (instance != null)
                        {
                            <span>CS @instance.CourseId @instance.CourseTitle</span>
                        }
                        else
                        {
                            <span>Loading Course Details...</span>
                        }
                    </div>
                </div>
                    
                <div class="tutor-content">
                    <!--Tutor Mode Chats-->
                    <div class="tutor-chat-container">
                        @foreach (var message in conversationData)
                        {
                            <div class="tutor-message @(message.role == "user" ? "user" : "bot")">
                                <div class="tutor-avatar">
                                    <i class="fas @(message.role == "user" ? "fa-user" : "fa-robot")"></i>
                                </div>
                                <div class="tutor-message-content">
                                    @message.content
                                </div>
                            </div>
                        }
                    </div>

                    <!--Error Message-->
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" style="margin: 10px; padding: 10px; border-radius: 5px; background-color: #fee2e2; color: #b91c1c; display: flex; align-items: center; gap: 8px;">
                            <i class="fas fa-exclamation-circle"></i>
                            <span>@errorMessage</span>
                            <button class="close-error" @onclick="() => errorMessage = null" style="margin-left: auto; background: none; border: none; cursor: pointer;">&times;</button>
                        </div>
                    }

                    <!--User Input-->
                    <div class="tutor-input-container">
                        <input type="text" class="tutor-input" placeholder="Ask anything..."
                               @bind="userInput" @onkeyup="HandleKeyPress">
                        <button class="tutor-send-button" @onclick="SendMessage" disabled="@isGenerating">
                            <i class="fas @(isGenerating ? "fa-spinner fa-spin" : "fa-paper-plane")"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!--Footer-->
        <div class="footer">
        </div>
    </div>
</div>


@code {
    // The instanceId is passed in the URL and used to load the specific tutor session data from the database
    [Parameter] public string? InstanceId { get; set; }

    private Instance? instance;
    private List<TutorConversationData> conversationData = new();
    private User? user;
    private string userInput = "";
    private bool isGenerating = false;
    private string? errorMessage; // To show the user if the AI is busy

    // On component initialization we load the corresponding instance from the database, initialize the LLM, and deserialize any existing conversation data to display in the UI
    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(InstanceId))
        {
            instance = await Db.GetInstanceByIdAsync(InstanceId);
            if (instance != null)
            {
                // Initialize LLM object
                instance.llm = new LLM(instance.Type);

                if (!string.IsNullOrEmpty(instance.Data) && instance.Data != "{}")
                {
                    try
                    {
                        conversationData = System.Text.Json.JsonSerializer.Deserialize<List<TutorConversationData>>(instance.Data)
                                           ?? new List<TutorConversationData>();
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Data Load Error: {ex.Message}");
                        errorMessage = "Failed to load conversation history.";
                        conversationData = new List<TutorConversationData>();
                    }
                }
            }
        }
    }

    // This method handles the entire flow of sending a message: saving the user's message, generating the tutor's response, and saving that response
    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isGenerating || instance == null) return;

        isGenerating = true;
        errorMessage = null;

        // Save User Message Block
        var currentInput = userInput;
        userInput = ""; // Clear UI input immediately
        await AppendMessageAndSave("user", currentInput);

        try
        {
            // Ensure LLM is initialized (should already be, but just in case)
            if (instance.llm == null)
            {
                instance.llm = new LLM(instance.Type);
            }

            // Generate LLM Response
            var tutorMessage = await llm.GenerateTutorResponse(instance.llm, currentInput, conversationData);

            // Save Tutor Response Block
            await AppendMessageAndSave("tutor", tutorMessage.content);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"LLM Error: {ex.Message}");
            errorMessage = "The tutor is having trouble connecting. Try again?";
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }

    // Allow pressing Enter to send message
    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }

    // Checking if user is authenticated on page load and redirecting if not, otherwise loading user data
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var userId = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "UserId");
            if (string.IsNullOrEmpty(userId))
            {
                NavManager.NavigateTo("/");
            }
            else
            {
                user = await Db.GetUserByIdAsync(int.Parse(userId));
                StateHasChanged();
            }
        }
    }

    // This method handles both appending a new message to the local conversation list and saving the entire conversation back to the database
    private async Task AppendMessageAndSave(string role, string content)
    {
        if (instance == null) return;

        // 1. Create the new data block
        var newMessage = new TutorConversationData
        {
            role = role,
            content = content
        };

        // 2. Add to the local list (the UI uses this)
        conversationData.Add(newMessage);

        // 3. Serialize the ENTIRE list back to JSON
        // This creates the [{"role":"tutor"...}, {"role":"user"...}] structure
        instance.Data = System.Text.Json.JsonSerializer.Serialize(conversationData);

        try
        {
            if (!string.IsNullOrEmpty(InstanceId))
            {
                // 4. Update the DB
                await Db.UpdateInstanceDataAsync(InstanceId, instance.Data);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Database Sync Error: {ex.Message}");
            errorMessage = "Message sent, but failed to save to history.";
        }
    }

}

