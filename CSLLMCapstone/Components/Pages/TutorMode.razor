@page "/dashboard/tutor/{instanceId}"
@using CSLLMCapstone.Services
@using CSLLMCapstone.Models
@rendermode InteractiveServer
@inject DbService Db
@inject LLMService llm
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<PageTitle>CS Study Cat - Tutor Mode</PageTitle>

<div class="dashboard-body">
    <!--Sidebar component-->
    @if (user != null)
    {
        <Sidebar FName="@(user.FName ?? "")" LName="@(user.LName ?? "")" />
    }
    else
    {
        <!--Pass Study Cat if user not found-->
        <Sidebar FName="Study" LName="Cat" />
    }
    
    <!--Main Content-->
    <div class="main-content">
        <!--Top Bar-->
        <div class="top-bar">
            <label for="sidebar-toggle" class="mobile-menu-btn">
                <i class="fas fa-bars"></i>
            </label>

            <div class="page-title">
                <h2><i class="fas fa-chalkboard-teacher"></i> Tutor Mode</h2>
                @if (!string.IsNullOrEmpty(InstanceId))
                {
                    <span class="instance-id-badge">Instance: @InstanceId</span>
                }
            </div>
            
            <a href="/dashboard" class="close-modal">&times;</a>
        </div>

        <!--Tutor Content - HARDCODED, MUST UPDATE W/ LLM INTEGRATION-->
        <div class="study-session-body">
            <div class="tutor-container">
                <!--Tutor Header-->
                <div class="tutor-header">
                    <div class="flashcards-title">
                        @if (instance != null)
                        {
                            <span>CS @instance.CourseId @instance.CourseTitle</span>
                        }
                        else
                        {
                            <span>Loading Course Details...</span>
                        }
                    </div>
                </div>
                    
                <div class="tutor-content">

                    <div class="tutor-chat-container">
                        @foreach (var message in conversationDatas)
                        {
                            <div class="tutor-message @(message.role == "user" ? "user" : "bot")">
                                <div class="tutor-avatar">
                                    <i class="fas @(message.role == "user" ? "fa-user" : "fa-robot")"></i>
                                </div>
                                <div class="tutor-message-content">
                                    @message.content
                                </div>
                            </div>
                        }
                    </div>

                    <div class="tutor-input-container">
                        <input type="text" class="tutor-input" placeholder="Ask anything..."
                               @bind="userInput" @onkeyup="HandleKeyPress">
                        <button class="tutor-send-button" @onclick="SendMessage" disabled="@isGenerating">
                            <i class="fas @(isGenerating ? "fa-spinner fa-spin" : "fa-paper-plane")"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!--Footer-->
        <div class="footer">
        </div>
    </div>
</div>


@code {
    [Parameter] public string? InstanceId { get; set; }

    private Instance? instance;
    private List<TutorConversationData> conversationDatas = new();
    private User? user;
    private string userInput = "";
    private bool isGenerating = false;
    private string? errorMessage; // To show the user if the AI is busy

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(InstanceId))
        {
            instance = await Db.GetInstanceByIdAsync(InstanceId);
            if (instance != null)
            {
                // Initialize LLM object
                instance.llm = new LLM(instance.Type);

                if (!string.IsNullOrEmpty(instance.Data) && instance.Data != "{}")
                {
                    try
                    {
                        conversationDatas = System.Text.Json.JsonSerializer.Deserialize<List<TutorConversationData>>(instance.Data)
                                           ?? new List<TutorConversationData>();
                    }
                    catch { /* Handle malformed JSON if necessary */ }
                }
            }
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isGenerating || instance == null) return;

        isGenerating = true;
        errorMessage = null;

        // Save User Message Block
        var currentInput = userInput;
        userInput = ""; // Clear UI input immediately
        await AppendMessageAndSave("user", currentInput);

        try
        {
            // Generate LLM Response
            var tutorMsg = await llm.GenerateTutorResponse(instance.llm, currentInput, conversationDatas);

            // Save Tutor Response Block
            await AppendMessageAndSave("tutor", tutorMsg.content);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"LLM Error: {ex.Message}");
            errorMessage = "The tutor is having trouble connecting. Try again?";
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var userId = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "UserId");
            if (string.IsNullOrEmpty(userId))
            {
                NavManager.NavigateTo("/");
            }
            else
            {
                user = await Db.GetUserByIdAsync(int.Parse(userId));
                StateHasChanged();
            }
        }
    }


    private async Task AppendMessageAndSave(string role, string content)
    {
        if (instance == null) return;

        // 1. Create the new data block
        var newMessage = new TutorConversationData
        {
            role = role,
            content = content
        };

        // 2. Add to the local list (the UI uses this)
        conversationDatas.Add(newMessage);

        // 3. Serialize the ENTIRE list back to JSON
        // This creates the [{"role":"tutor"...}, {"role":"user"...}] structure
        instance.Data = System.Text.Json.JsonSerializer.Serialize(conversationDatas);

        try
        {
            // 4. Update the DB
            await Db.SaveInstanceAsync(instance);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Database Sync Error: {ex.Message}");
            errorMessage = "Message sent, but failed to save to history.";
        }
    }

}

