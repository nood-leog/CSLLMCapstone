@page "/dashboard/flash/{instanceId}"
@using CSLLMCapstone.Services
@using CSLLMCapstone.Models
@rendermode InteractiveServer
@inject DbService Db
@inject LLMService Llm
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<PageTitle>CS Study Cat - Flashcards Mode</PageTitle>

<div class="dashboard-body">
    <!--Sidebar component-->
    @if (user != null)
    {
        <Sidebar FName="@(user.FName ?? "")" LName="@(user.LName ?? "")" />
    }
    else
    {
        <!--Pass Study Cat if user not found-->
        <Sidebar FName="Study" LName="Cat" />
    }
    
    <!--Main Content-->
    <div class="main-content">
        <!--Top Bar-->
        <div class="top-bar">
            <label for="sidebar-toggle" class="mobile-menu-btn">
                <i class="fas fa-bars"></i>
            </label>

            <div class="page-title">
                <h2><i class="fas fa-sticky-note"></i> Flashcards Mode</h2>
                @if (!string.IsNullOrEmpty(InstanceId))
                {
                    <span class="instance-id-badge">Instance: @InstanceId</span>
                }
            </div>
            
            <a href="/dashboard" class="close-modal">&times;</a>
        </div>

        <!--Dynamic Flashcards Mode-->
        <div class="study-session-body">
            <div class="flashcards-container">
                <!--Flashcards Header-->
                <div class="flashcards-header">
                    <div class="flashcards-title">Study Session: @InstanceId</div>
                </div>

                <!--Flashcards Main Section-->
                <div class="flashcard-main-area">
                    @if (flashcards.Any())
                    {
                        var currentCard = flashcards[currentCardIndex];

                        <div class="flashcard @(isFlipped ? "flipped" : "")" @onclick="ToggleFlashcard">
                            <div class="flashcard-inner">
                                <div class="flashcard-front">
                                    <div class="flashcard-label">Term</div>
                                    <div class="flashcard-content">
                                        @currentCard.Item1
                                    </div>
                                </div>
                                <div class="flashcard-back">
                                    <div class="flashcard-label back">Definition</div>
                                    <div class="flashcard-content">
                                        @currentCard.Item2
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="flashcard-controls">
                            <button class="flashcard-nav-button" @onclick="GoToPreviousCard" disabled="@(currentCardIndex == 0)">
                                <i class="fas fa-chevron-left"></i>
                            </button>

                            <button class="flashcard-flip-button" @onclick="ToggleFlashcard">
                                Flip Card
                            </button>

                            <button class="flashcard-nav-button" @onclick="GoToNextCard" disabled="@(currentCardIndex >= flashcards.Count - 1)">
                                <i class="fas fa-chevron-right"></i>
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="flashcard-content">
                            Generating cards or no cards found...
                        </div>
                    }

                    <div class="flashcard-counter">
                        Card <span>@(flashcards.Any() ? currentCardIndex + 1 : 0)</span> of <span>@flashcards.Count</span>
                    </div>
                </div>
            </div>
        </div>


        <!--Footer-->
        <div class="footer">
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? InstanceId { get; set; }

    private bool isFlipped = false;
    private int currentCardIndex = 0;
    List<Tuple<string, string>> flashcards = new List<Tuple<string, string>>();

    private void ToggleFlashcard()
    {
        isFlipped = !isFlipped;
    }

    protected override async Task OnInitializedAsync()
    {
        // Load instance data here if needed
        if (!string.IsNullOrEmpty(InstanceId))
        {
            // get the instance from instance id
            Instance? instance = await Db.GetInstanceByIdAsync(InstanceId);

            if(instance != null)
            {
                // call llm service to generate flashcard content based on instance data
                flashcards = Llm.GenerateFlashCardDataList(instance.Data);
            }
            
        }
    }

    private void GoToPreviousCard()
    {
        if (currentCardIndex > 0)
        {
            currentCardIndex--;
            isFlipped = false; // Reset flip state when navigating
        }
	}

    private void GoToNextCard()
    {
        // Assuming we have a total of 20 cards for demonstration
        if (currentCardIndex < 19)
        {
            currentCardIndex++;
            isFlipped = false; // Reset flip state when navigating
        }
	}
}

@code {
    // User details - to be fetched from DB
    private User? user;

    // Checking if user is authenticated
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 1. Check local storage for the UserID
            var userId = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "UserId");

            if (string.IsNullOrEmpty(userId))
            {
                // 2. If no user found, boot them to login
                NavManager.NavigateTo("/");
            }
            else
            {
                // 3. User is valid, fetch the user details and show the UI
                user = await Db.GetUserByIdAsync(int.Parse(userId));
                StateHasChanged(); // Force a re-render now that we have data
            }
        }
    }
}
   