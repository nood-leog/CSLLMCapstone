@page "/dashboard/flash/{instanceId}/{CourseID:int}"
@using CSLLMCapstone.Services
@using CSLLMCapstone.Models
@using System.Text.Json
@rendermode InteractiveServer
@inject DbService Db
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject LLMService LlmService


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<PageTitle>CS Study Cat - Flashcards Mode</PageTitle>

<div class="dashboard-body">
    <!--Sidebar component-->
    @if (user != null)
    {
        <Sidebar FName="@(user.FName ?? "")" LName="@(user.LName ?? "")" />
    }
    else
    {
        <!--Pass Study Cat if user not found-->
        <Sidebar FName="Study" LName="Cat" />
    }
    
    <!--Main Content-->
    <div class="main-content">
        <!--Top Bar-->
        <div class="top-bar">
            <label for="sidebar-toggle" class="mobile-menu-btn">
                <i class="fas fa-bars"></i>
            </label>

            <div class="page-title">
                <h2><i class="fas fa-sticky-note"></i> Flashcards Mode</h2>
                @if (!string.IsNullOrEmpty(InstanceId))
                {
                    <span class="instance-id-badge">Instance: @InstanceId</span>
                }
            </div>

            <a href="/dashboard" class="close-modal">&times;</a>
        </div>
            @if (isLoading)
            {
                <p>Loading flashcards...</p>
            }
            else if (flashcards.Count == 0)
            {
                <p>No flashcards generated.</p>
            }
            else
            {
                <!--Flashcards Content-->
                <div class="study-session-body">
                    <div class="flashcards-container">
                        <div class="flash-header">
                            <div class="flashcards-title">
                               @courseTitle Flashcards
                            </div>
                        </div>

                        <div class="flashcard-main-area">
                            <!--Flip Toggle-->
                            <input type="checkbox" id="flashcard-toggle" @bind="isFlipped"
                                style="display:none"/>
                            <!--Flashcard-->
                            <label for="flashcard-toggle" class="flashcard">
                                <div class="flashcard-inner">
                                    <!--Front-->
                                    <div class="flashcard-front">
                                        <div class="flashcard-label">Term</div>
                                        <div class="flashcard-content">
                                            @flashcards[currentIndex].Item1
                                        </div>
                                    </div>
                                    <!--Back-->
                                    <div class="flashcard-back">
                                        <div class="flashcard-label back">Definition</div>
                                        <div class="flashcard-content">
                                            @flashcards[currentIndex].Item2
                                        </div>
                                    </div>
                                </div>
                            </label>

                            <!--Controls-->
                            <div class="flashcard-controls">
                                <button class="flashcard-nav-button" @onclick="PrevCard" 
                                    disabled="@(currentIndex == 0)">
                                    <i class="fas fa-chevron-left"></i>
                                </button>

                                <label for="flashcard-toggle" class="flashcard-flip-button">
                                    Flip Card
                                </label>

                                <button class="flashcard-nav-button" @onclick="NextCard"
                                    disabled="@(currentIndex == flashcards.Count -1)">
                                    <i class="fas fa-chevron-right"></i>
                                </button>
                            </div>
                            <div class="flashcard-counter">
                                Card <span>@(currentIndex + 1)</span> of
                                <span>@flashcards.Count</span>
                            </div>
                        </div>
                    </div>
                </div>   
            }
@*
