@code {

    // Store the clicked on topic for courseOverview
    private class InstanceTopInfo
    {
        public int courseId { get; set; }
        public int? topicId { get; set; }
        public string? topicName { get; set; }
    }

    [Parameter]
    public string? InstanceId { get; set; }
    [Parameter]
    public int CourseId { get; set; }

    private Instance? instance;
    private InstanceTopInfo? insTopInfo;

    private bool isFlipped = false;
    private bool isLoading = true;
    private string courseTitle = "";
    private string courseDesc = "";
    private List<string> topicStrings = new();

    private List<Tuple<string, string>> flashcards = new();
    private int currentIndex = 0;

    private Tuple<string, string>? CurrentCard => flashcards.Count > 0 ? flashcards[currentIndex] : null;


    private void ToggleFlashcard()
    {
        isFlipped = !isFlipped;
    }

    protected override async Task OnInitializedAsync()
    {
        // Load instance data here if needed
        if (string.IsNullOrEmpty(InstanceId))
        {
            NavManager.NavigateTo("/dashboard");
            return;
        }

        if (CourseId <= 0)
        {
            NavManager.NavigateTo("/dashboard");
            return;
        }

        instance = await Db.GetInstanceByIdAsync(InstanceId);

        if (instance == null || instance.Type != InstanceType.Flash)
        {
            NavManager.NavigateTo("/dashboard");
            return;
        }

        // try to read the topic payload that is stored
        try
        {
            insTopInfo = JsonSerializer.Deserialize<InstanceTopInfo>(instance.Data,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        }
        catch
        {
            insTopInfo = null;
        }

        // Load course data
        courseTitle = await Db.GetCourseNameByCourseIdAsync(CourseId) ?? "";
        courseDesc = await Db.GetCourseDescriptionByCourseIdAsync(CourseId) ?? "";

        //Check wether topic or course overview was clicked
        if (!string.IsNullOrWhiteSpace(insTopInfo?.topicName))
        {
            topicStrings = new List<string> { insTopInfo!.topicName! };
        }
        else
        {
            topicStrings = await Db.GetTopicNamesByCourseIDAsnyc(CourseId);
        }

        if (string.IsNullOrWhiteSpace(courseTitle))
        {
            NavManager.NavigateTo("/dashboard");
            return;
        }

        // Get the topic list for the courses
        string historyJson = instance.Data; // no deserialization

        var llm = new LLM(InstanceType.Flash);

        flashcards = await LlmService.GenerateFlashCardDataListAsync(llm, courseTitle, courseDesc,
            topicStrings, historyJson);

        //Save history
        await Db.UpdateInstanceDataAsync(instance.InstanceId, JsonSerializer.Serialize(flashcards));

        isLoading = false;
    }

    private void NextCard()
    {
        if (currentIndex < flashcards.Count - 1)
        {
            currentIndex++;
            isFlipped = false;
        }
    }

    private void PrevCard()
    {
        if (currentIndex > 0)
        {
            currentIndex--;
            isFlipped = false;
        }
    }


}

@code {
    // User details - to be fetched from DB
    private User? user;

    // Checking if user is authenticated
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 1. Check local storage for the UserID
            var userId = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "UserId");

            if (string.IsNullOrEmpty(userId))
            {
                // 2. If no user found, boot them to login
                NavManager.NavigateTo("/");
            }
            else
            {
                // 3. User is valid, fetch the user details and show the UI
                user = await Db.GetUserByIdAsync(int.Parse(userId));
                StateHasChanged(); // Force a re-render now that we have data
            }
        }
    }
}