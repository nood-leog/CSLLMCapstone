@page "/dashboard/flash"
@rendermode InteractiveServer

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<PageTitle>CS Study Cat - Flashcards Mode</PageTitle>

<div class="dashboard-body">
    <!--Sidebar component-->
    <Sidebar />

    <!--Main Content-->
    <div class="main-content">
        <!--Top Bar-->
        <div class="top-bar">
            <label for="sidebar-toggle" class="mobile-menu-btn">
                <i class="fas fa-bars"></i>
            </label>

            <div class="page-title">
                <h2><i class="fas fa-sticky-note"></i> Flashcards Mode</h2>
            </div>

            <a href="/dashboard" class="close-modal">&times;</a>
        </div>

        <!--Flashcards Content-->
        <div class="study-session-body">
            <div class="flashcards-container">
                <div class="flashcards-header">
                    <div class="flashcards-title">Lorem Ipsum Flashcards</div>
                    <div class="flashcards-progress">5/20</div>
                </div>

                <div class="flashcard-main-area">
                    <!-- FLASHCARD FLIP SYSTEM -->
                    <input type="checkbox" id="flashcard-toggle" style="display: none;">

                    <!-- Label that toggles the checkbox when clicked -->
                    <button type="button" class="flashcard" @onclick="ToggleFlashcard">
                        <span class="flashcard-inner">
                            <span class="flashcard-front">
                                <span class="flashcard-label">Term</span>
                                <span class="flashcard-content">
                                    Lorem ipsum dolor sit amet
                                </span>
                            </span>
                            <span class="flashcard-back">
                                <span class="flashcard-label back">Definition</span>
                                <span class="flashcard-content">
                                    Consectetur adipiscing elit. Quisque faucibus ex sapien vitae pellentesque sem placerat. In id cursus mi pretium tellus duis convallis.
                                </span>
                            </span>
                        </span>
                    </button>

                    <div class="flashcard-controls">
                        <button class="flashcard-nav-button">
                            <i class="fas fa-chevron-left"></i>
                        </button>

                        <label for="flashcard-toggle" class="flashcard-flip-button">
                            Flip Card
                        </label>

                        <button class="flashcard-nav-button">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>

                    <div class="flashcard-counter">
                        Card <span>5</span> of <span>20</span>
                    </div>
                </div>

                <div class="flashcard-stats">
                    <div class="flashcard-actions">
                        <button class="flashcard-action-btn">
                            <i class="fas fa-random"></i> Shuffle
                        </button>
                        <button class="flashcard-action-btn">
                            <i class="fas fa-star"></i> Star
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!--Footer-->
        <div class="footer">
        </div>
    </div>
</div>

@code {
    private void ToggleFlashcard()
    {
        // Implement your flashcard flip logic here
        // For now, this is just a placeholder
    }
}