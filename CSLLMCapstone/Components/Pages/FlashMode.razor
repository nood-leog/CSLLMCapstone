@page "/dashboard/flash/{instanceId}"
@using CSLLMCapstone.Services
@using CSLLMCapstone.Models
@rendermode InteractiveServer
@inject DbService Db
@inject NavigationManager NavManager

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<PageTitle>CS Study Cat - Flashcards Mode</PageTitle>

<div class="dashboard-body">
    <!--Sidebar component-->
    <Sidebar />
    
    <!--Main Content-->
    <div class="main-content">
        <!--Top Bar-->
        <div class="top-bar">
            <label for="sidebar-toggle" class="mobile-menu-btn">
                <i class="fas fa-bars"></i>
            </label>

            <div class="page-title">
                <h2><i class="fas fa-sticky-note"></i> Flashcards Mode</h2>
                @if (!string.IsNullOrEmpty(InstanceId))
                {
                    <span class="instance-id-badge">Instance: @InstanceId</span>
                }
            </div>
            
            <a href="/dashboard" class="close-modal">&times;</a>
        </div>

        <!--Flashcards Content-->
        <div class="study-session-body">
            <div class="flashcards-container">
                <div class="flashcards-header">
                    <div class="flashcards-title">Lorem Ipsum Flashcards</div>
                    <div class="flashcards-progress">5/20</div>
                </div>

                <div class="flashcard-main-area">
                    <!-- FLASHCARD FLIP SYSTEM -->
                    <input type="checkbox" id="flashcard-toggle" style="display: none;">

                    <!-- Label that toggles the checkbox when clicked -->
                    <label for="flashcard-toggle" class="flashcard">
                        <div class="flashcard-inner">
                            <div class="flashcard-front">
                                <div class="flashcard-label">Term</div>
                                <div class="flashcard-content">
                                    Lorem ipsum dolor sit amet
                                </div>
                            </div>
                            <div class="flashcard-back">
                                <div class="flashcard-label back">Definition</div>
                                <div class="flashcard-content">
                                    Consectetur adipiscing elit. Quisque faucibus ex sapien vitae pellentesque sem placerat. In id cursus mi pretium tellus duis convallis.
                                </div>
                            </div>
                        </div>
                    </label>

                    <div class="flashcard-controls">
                        <button class="flashcard-nav-button">
                            <i class="fas fa-chevron-left"></i>
                        </button>

                        <label for="flashcard-toggle" class="flashcard-flip-button">
                            Flip Card
                        </label>

                        <button class="flashcard-nav-button">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>

                    <div class="flashcard-counter">
                        Card <span>5</span> of <span>20</span>
                    </div>
                </div>

                <div class="flashcard-stats">
                    <div class="flashcard-actions">
                        <button class="flashcard-action-btn">
                            <i class="fas fa-random"></i> Shuffle
                        </button>
                        <button class="flashcard-action-btn">
                            <i class="fas fa-star"></i> Star
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!--Footer-->
        <div class="footer">
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? InstanceId { get; set; }

    private bool isFlipped = false;

    private void ToggleFlashcard()
    {
        isFlipped = !isFlipped;
    }

    protected override async Task OnInitializedAsync()
    {
        // Load instance data here if needed
        if (!string.IsNullOrEmpty(InstanceId))
        {
            // TODO: Load flashcard data based on InstanceId from database
            Console.WriteLine($"Flashcard instance loaded: {InstanceId}");
        }
    }
}