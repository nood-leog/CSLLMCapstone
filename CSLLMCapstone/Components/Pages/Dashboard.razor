@page "/dashboard"
@rendermode InteractiveServer
@using CSLLMCapstone.Services
@using CSLLMCapstone.Models
@inject DbService Db
@inject UserSessionService UserSession
@inject NavigationManager NavManager

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<PageTitle>CS Study Cat - Dashboard</PageTitle>

@if (!UserSession.IsLoggedIn)
{
    <div>Redirecting to login...</div>
}
else
{
    <div class="dashboard-body">
        <!--Sidebar component-->
        <Sidebar />
        <!--Main Content-->
        <div class="main-content">
            <!--Top Bar-->
            <div class="top-bar">
                <label for="sidebar-toggle" class="mobile-menu-btn">
                    <i class="fas fa-bars"></i>
                </label>

                <div class="page-title">
                    <h2>Courses Dashboard</h2>
                </div>
            </div>

            <!--Courses Container-->
            <div class="courses-container">
                <div class="courses-header">
                    <h3>Your Computer Science Courses</h3>
                    <p>Click on a course to view details and study materials</p>
                </div>

                <!--Dynamic Courses Grid-->
                <div class="courses-grid">
                    @if (isLoading)
                    {
                        <p>Loading courses...</p>
                    }
                    else if (courses == null || !courses.Any())
                    {
                        <p>No courses found.</p>
                    }
                    else
                    {
                        @foreach (var course in courses)
                        {
                            <div class="course-card" @onclick='() => HandleCourseClick(course.CourseId, course.Title, course.CourseDesc)'>
                                <div class="course-content">
                                    <div class="course-number">@course.Title</div>
                                    <div class="course-name">@course.CourseDesc</div>
                                </div>
                                <div class="course-footer">
                                    <div class="course-action">View Details</div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <!--Footer-->
            <div class="footer">
            </div>
        </div>

        <!--Display Course Overview if course is clicked-->
        @if (isCourseClicked)
        {
            <CourseOverview CourseID="@courseID" CourseTitle="@courseTitle" CourseDesc="@courseDesc" OnClose="() => isCourseClicked = false"/>
        }
    </div>
}

@code {
    private bool isCourseClicked = false;
    private int courseID;
    private string? courseTitle;
    private string? courseDesc;

    private List<Course> courses = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        // Check if user is logged in, if not redirect to login
        if (!UserSession.IsLoggedIn)
        {
            NavManager.NavigateTo("/", replace: true);
            return;
        }

        isLoading = true;
        courses = await Db.GetAllCoursesAsync();
        isLoading = false;
    }

    private void HandleCourseClick(int selectedCourseID, string selectedCourseTitle, string selectedCourseDesc)
    {
        isCourseClicked = true;
        courseID = selectedCourseID;
        courseTitle = selectedCourseTitle;
        courseDesc = selectedCourseDesc;
    }
}