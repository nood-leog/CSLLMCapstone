<!--HandleFavoriteClick Logic for courses-->
@code {
    private async Task HandleFavoriteClick(Course course)
    {
        try
        {
            // Toggle the favorite status
            course.IsFavorite = !course.IsFavorite;

            // Update the database with the new favorite status
            await Db.UpdateCourseFavoriteStatusAsync(course.CourseId, course.IsFavorite);

            // Refresh the dashboard to update courses
            courses = await Db.GetAllCoursesAsync();
            StateHasChanged(); // Force a re-render to reflect changes
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating favorite status: {ex.Message}");
        }
    }
}