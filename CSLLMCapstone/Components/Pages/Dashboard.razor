@page "/dashboard"
@rendermode InteractiveServer

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<PageTitle>CS Study Cat - Dashboard</PageTitle>

<div class="dashboard-body">
    <!--Sidebar component-->
    <Sidebar />
    <!--Main Content-->
    <div class="main-content">
        <!--Top Bar-->
        <div class="top-bar">
            <label for="sidebar-toggle" class="mobile-menu-btn">
                <i class="fas fa-bars"></i>
            </label>

            <div class="page-title">
                <h2>Courses Dashboard</h2>
            </div>

        </div>

        <!--Courses Container-->
        <div class="courses-container">
            <div class="courses-header">
                <h3>Your Computer Science Courses</h3>
                <p>Click on a course to view details and study materials</p>
            </div>

            <!--HARDCODED - Change later with courses data from DB-->
            <div class="courses-grid">
                <!-- CS111 Course Card -->
                <div class="course-card" @onclick='() => HandleCourseClick("CS 111", "Programming Fundamentals I")'>
                    <div class="course-content">
                        <div class="course-number">CS 111</div>
                        <div class="course-name">Programming Fundamentals I</div>
                    </div>
                    <div class="course-footer">
                        <div class="course-action">View Details</div>
                    </div>
                </div>

                <!-- CS301 Course Card -->
                <div class="course-card" @onclick='() => HandleCourseClick("CS 301", "Data Structures")'>
                    <div class="course-content">
                        <div class="course-number">CS 301</div>
                        <div class="course-name">Data Structures</div>
                    </div>
                    <div class="course-footer">
                        <div class="course-action">View Details</div>
                    </div>
                </div>
            </div>
        </div>

        <!--Footer-->
        <div class="footer">
        </div>
    </div>

    <!--Display Course Overview if course is clicked-->
    @if (isClicked)
    {
        <CourseOverview CourseID="@courseID" CourseTitle="@courseTitle" OnClose="() => isClicked = false"/>
    }
</div>

<!--HandleCourseClick Logic - Set flag to true when course clicked and false if not-->
@code {
    // isClicked flag
    private bool isClicked = false;
    // courseID to hold clicked course ID
    private string? courseID;
    // courseTitle to hold clicked course title\
    private string? courseTitle;

    private void HandleCourseClick(string selectedCourseID, string selectedCourseTitle)
    {
        isClicked = true; // flip flag
        courseID = selectedCourseID; // set courseID
        courseTitle = selectedCourseTitle; // set courseTitle
    }
}