@page "/dashboard"
@using CSLLMCapstone.Models
@using CSLLMCapstone.Services
@rendermode InteractiveServer
@inject DbService Db
@inject NavigationManager NavManager

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<PageTitle>CS Study Cat - Dashboard</PageTitle>

<div class="dashboard-body">
    <!--Sidebar component-->
    <Sidebar />
    <!--Main Content-->
    <div class="main-content">
        <!--Top Bar-->
        <div class="top-bar">
            <label for="sidebar-toggle" class="mobile-menu-btn">
                <i class="fas fa-bars"></i>
            </label>

            <div class="page-title">
                <h2>Courses Dashboard</h2>
            </div>

        </div>

        <!--Courses Container-->
        <div class="courses-container">
            <div class="courses-header">
                <h3>Your Computer Science Courses</h3>
                <p>Click on a course to view details and study materials</p>
            </div>

            <!--Dynamic logic for displaying course modals-->
            <div class="courses-grid">
                @if (courses == null || !courses.Any())
                {
                    <p><em>Loading courses...</em></p>
                }
                else
                {
                    @foreach (var course in courses)
                    {
                        <!--Course Card-->
                        <div class="course-card" @onclick="() => HandleCourseClick(course)">
                            <div class="course-content">
                                <div class="course-number">@course.CourseId</div>
                                <div class="course-name">@course.Title</div>
                            </div>
                            <div class="course-footer">
                                <div class="course-action">View Details</div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!--Footer-->
        <div class="footer">
        </div>
    </div>

    <!--Display Course Overview if course is clicked-->
    @if (isCourseClicked && selectedCourse != null)
    {
        <CourseOverview 
            CourseID="@selectedCourse.CourseId.ToString()"
            CourseTitle="@selectedCourse.Title"
            CourseDesc="@selectedCourse.CourseDesc"
            OnClose="() => isCourseClicked = false"
        />
    }
</div>

<!--HandleCourseClick Logic - Set flag to true when course clicked and false if not-->
<!--Fetch course data on component mount-->
@code {
    // List of courses - to be fetched from DB
    private List<Course> courses = new List<Course>();

    // isCourseClicked flag
    private bool isCourseClicked = false;

    // The selected course
    private Course? selectedCourse;

    // Fetch all the course data when the component is first initialized
    protected override async Task OnInitializedAsync()
    {
        courses = await Db.GetAllCoursesAsync();
    }

    private void HandleCourseClick(Course course)
    {
        selectedCourse = course; // set selected course
        isCourseClicked = true; //  flip flag
    }
}