@page "/change-password"

<PageTitle>CS Study Cat - Change Password</PageTitle>

<div class="forgot-container">
    <div class="forgot-logo">
        <h1>CS Study Cat</h1>
    </div>

    <div class="forgot-header">
        <h2>Change Password</h2>
        <p>Enter your credentials to securely update your password</p>
    </div>

    <!--Change Password form-->
    <form id="changeForm">
        <!--CWU Email input-->
        <div class="forgot-form-group">
            <label class="forgot-label">CWU Email</label>
            <div class="forgot-input-with-icon">
                <i class="fas fa-user"></i>
                <input type="text" class="forgot-input" placeholder="Enter your CWU email" required>
            </div>
        </div>

        <!--New Password input-->
        <div class="forgot-form-group">
            <label class="forgot-label">New Password</label>
            <div class="forgot-input-with-icon">
                <i class="fas fa-lock"></i>
                <input type="password" class="forgot-input" placeholder="Create a strong new password" required>
            </div>
        </div>

        <!--Confirm New Password input-->
        <div class="forgot-form-group">
            <label class="forgot-label">Confirm New Password</label>
            <div class="forgot-input-with-icon">
                <i class="fas fa-key"></i>
                <input type="password" class="forgot-input" placeholder="Confirm your new password" id="newPassword" required>
            </div>
        </div>

        <!--Update Password button-->
        <button type="submit" class="forgot-submit-btn" id="submitBtn">Update Password</button>
    </form>

    <!--Back to Sign In link-->
    <div class="forgot-back-link">
        <a href="/">
            <i class="fas fa-arrow-left"></i> Back to Sign In
        </a>
    </div>
</div>