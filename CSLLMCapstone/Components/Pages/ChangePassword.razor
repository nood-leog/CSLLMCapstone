@page "/change-password"
@using CSLLMCapstone.Models
@using CSLLMCapstone.Services
@using System.Text.RegularExpressions
@rendermode InteractiveServer
@inject DbService Db
@inject NavigationManager NavManager

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<PageTitle>CS Study Cat - Change Password</PageTitle>

<div class="forgot-container">
    <div class="forgot-logo">
        <h1>CS Study Cat</h1>
    </div>

    <div class="forgot-header">
        <h2>Change Password</h2>
        <p>Enter your credentials to securely update your password</p>
    </div>

    <!--Change Password form-->
    <EditForm Model="this" OnValidSubmit="HandleChangePassword" id="changeForm">
        <!--CWU Email input-->
        <div class="forgot-form-group">
            <label class="forgot-label">CWU Email</label>
            <div class="forgot-input-with-icon">
                <i class="fas fa-user"></i>
                <InputText @bind-Value="cwuEmail" type="text" class="forgot-input" placeholder="Enter your CWU email" required />
            </div>
        </div>

        <!--New Password input-->
        <div class="forgot-form-group">
            <label class="forgot-label">New Password</label>
            <div class="forgot-input-with-icon">
                <i class="fas fa-lock"></i>
                <InputText @bind-Value="newPassword" type="password" class="forgot-input" placeholder="Create a strong new password" required />
            </div>
        </div>

        <!--Confirm New Password input-->
        <div class="forgot-form-group">
            <label class="forgot-label">Confirm New Password</label>
            <div class="forgot-input-with-icon">
                <i class="fas fa-key"></i>
                <InputText @bind-Value="confirmNewPassword" type="password" class="forgot-input" placeholder="Confirm your new password" id="newPassword" required />
            </div>
        </div>

        <!--Input Validation Error Message-->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" style="color: red; background-color: #ffe6e6; padding: 10px; border-radius: 5px; margin-bottom: 15px; border: 1px solid red;">
                <i class="fas fa-exclamation-circle"></i> @errorMessage
            </div>
        }

        <!--Update Password button-->
        <button type="submit" class="forgot-submit-btn" id="submitBtn">Update Password</button>
    </EditForm>

    <!--Back to Sign In link-->
    <div class="forgot-back-link">
        <a href="/">
            <i class="fas fa-arrow-left"></i>Back to Sign In
        </a>
    </div>
</div>

<!--ChangePassword Logic-->
@code {
    // Declare change password variables
    private string cwuEmail = "";
    private string newPassword = "";
    private string confirmNewPassword = "";

    // Store the input validation error message
    private string errorMessage = "";

    // Handle the change password process
    private async Task HandleChangePassword()
    {
        // Reset error message
        errorMessage = "";

        // Input validation here...
        if (string.IsNullOrEmpty(cwuEmail) || !cwuEmail.ToLower().EndsWith("@cwu.edu") || cwuEmail.Length > 100)
        {
            errorMessage = "You must use a valid CWU email ending in @cwu.edu.";
            return;
        }

        var hasUpper = new Regex(@"[A-Z]+");
        var hasSpecial = new Regex(@"[!@#$%^&*()_+=\[{\]};:<>|./?,-]+");

        if (string.IsNullOrEmpty(newPassword) || newPassword.Length < 7)
        {
            errorMessage = "Password must be at least 7 characters long.";
            return;
        }
        else if (!hasUpper.IsMatch(newPassword))
        {
            errorMessage = "Password must contain at least one capital letter.";
            return;
        }
        else if (!hasSpecial.IsMatch(newPassword))
        {
            errorMessage = "Password must contain at least one special character.";
            return;
        }

        if (newPassword != confirmNewPassword)
        {
            errorMessage = "Passwords do not match. Please try again.";
            return;
        }

        // Save to DB here...
        try
        {
            // First check if cwu email exists
            bool isTaken = await Db.IsEmailRegisteredAsync(cwuEmail);

            if (!isTaken)
            {
                errorMessage = "This email is not registered. Please try creating an account.";
                return;
            }

            // Second check if new password is different from the old one
            bool isSameAsOld = await Db.IsPasswordSameAsOldAsync(cwuEmail, newPassword);

            if (isSameAsOld)
            {
                errorMessage = "New password cannot be the same as the old password. Please choose a different password.";
                return;
            }

            // Update the user's password
            await Db.UpdateUserPasswordAsync(cwuEmail, newPassword);

            // Redirect to Sign In page upon successful password update
            NavManager.NavigateTo("/");
        }
        catch (Exception)
        {
            errorMessage = "An error occurred while updating your password. Please try again later.";
            return;
        }
    }
}