@page "/register"
@using CSLLMCapstone.Models
@using CSLLMCapstone.Services
@rendermode InteractiveServer
@inject DbService Db
@inject NavigationManager NavManager

<h3>Register New User</h3>

<EditForm Model="@newUser" OnValidSubmit="HandleRegistration">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>First Name:</label>
        <InputText @bind-Value="newUser.FName" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Last Name:</label>
        <InputText @bind-Value="newUser.LName" class="form-control" />
    </div>
    <div class="mb-3">
        <label>CWU Email:</label>
        <InputText @bind-Value="newUser.CwuEmail" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Major:</label>
        <InputText @bind-Value="newUser.Major" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Password:</label>
        <InputText @bind-Value="newUser.Password" type="password" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Sign Up</button>
</EditForm>

@code {
    private User newUser = new User();

    private async Task HandleRegistration()
    {
        // Set defaults if needed
        newUser.GraduationDate = 2025;

        // Save to DB using your service
        await Db.CreateUserAsync(newUser);

        // Clear form or redirect
        NavManager.NavigateTo("/");
    }
}