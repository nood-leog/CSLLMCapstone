@page "/create-account"
@using CSLLMCapstone.Models
@using CSLLMCapstone.Services
@using System.Text.RegularExpressions
@rendermode InteractiveServer
@inject DbService Db
@inject NavigationManager NavManager

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<PageTitle>CS Study Cat - Create Account</PageTitle>

<div class="signup-body">
    <div class="signup-container">
        <div class="signup-logo">
            <h1>CS Study Cat</h1>
        </div>

        <div class="signup-header">
            <h2>Create Account</h2>
            <p>Register for a new account to access CS Study Cat</p>
        </div>

        <!--Create Account form-->
        <EditForm Model="@newUser" OnValidSubmit="HandleCreateAccount" id="signupForm">
            <div class="signup-name-fields">
                <!--First/Last Name inputs-->
                <div class="signup-form-group">
                    <label class="signup-label" for="firstName">First Name</label>
                    <div class="signup-input-with-icon">
                        <i class="fas fa-user"></i>
                        <InputText @bind-Value="newUser.FName" type="text" id="firstName" class="signup-input" placeholder="John" required />
                    </div>
                </div>
                <div class="signup-form-group">
                    <label class="signup-label" for="lastName">Last Name</label>
                    <div class="signup-input-with-icon">
                        <i class="fas fa-user"></i>
                        <InputText @bind-Value="newUser.LName" type="text" id="lastName" class="signup-input" placeholder="Doe" required />
                    </div>
                </div>
            </div>

            <!--CWU Email input-->
            <div class="signup-form-group">
                <label class="signup-label" for="email">CWU Email</label>
                <div class="signup-input-with-icon">
                    <i class="fas fa-envelope"></i>
                    <InputText @bind-Value="newUser.CwuEmail" type="email" id="email" class="signup-input" placeholder="student@cwu.edu" required />
                </div>
            </div>

            <div class="signup-name-fields">
                <!--Major input-->
                <div class="signup-form-group">
                    <label class="signup-label" for="major">Major</label>
                    <div class="signup-input-with-icon">
                        <i class="fas fa-graduation-cap"></i>
                        <InputSelect @bind-Value="newUser.Major" id="major" class="signup-input" placeholder="Computer Science" required>
                            <option value="">Select Major</option>
                            @foreach (var m in MajorOptions)
                            {
                                <option value="@m">@m</option>
                            }
                        </InputSelect>
                    </div>
                </div>
                <!--Minor input-->
                <div class="signup-form-group">
                    <label class="signup-label" for="minor">Minor</label>
                    <div class="signup-input-with-icon">
                        <i class="fas fa-graduation-cap"></i>
                        <InputSelect @bind-Value="newUser.Minor" id="minor" class="signup-input" placeholder="Applied Computer Science" >
                            <option value="">Select Minor</option>
                            @foreach (var m in MinorOptions)
                            {
                                <option value="@m">@m</option>
                            }
                        </InputSelect>
                    </div>
                </div>
            </div>

            <!--Graduation Date input-->
            <div class="signup-form-group">
                <label class="signup-label" for="graduationDate">Graduation Date</label>
                <div class="signup-input-with-icon">
                    <i class="fas fa-calendar-alt"></i>
                    <InputNumber
                        @bind-value="newUser.GraduationDate" 
                        type="number" 
                        id="graduationDate" 
                        class="signup-input" 
                        placeholder="2026"
                        min="2026"
                        max="2030"
                        required 
                    />
                </div>
            </div>

            <!--Password input-->
            <div class="signup-form-group">
                <label class="signup-label" for="password">Password</label>
                <div class="signup-input-with-icon">
                    <i class="fas fa-lock"></i>
                    <InputText @bind-value="newUser.Password" type="password" id="password" class="signup-input" placeholder="Create a strong password" required />
                </div>
            </div>

            <!--Confirm Password input-->
            <div class="signup-form-group">
                <label class="signup-label" for="confirmPassword">Confirm Password</label>
                <div class="signup-input-with-icon">
                    <i class="fas fa-lock"></i>
                    <InputText @bind-Value="confirmPassword" type="password" id="confirmPassword" class="signup-input" placeholder="Confirm your password" required />
                </div>
            </div>

            <!--Input Validation Error Message-->
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" style="color: red; background-color: #ffe6e6; padding: 10px; border-radius: 5px; margin-bottom: 15px; border: 1px solid red;">
                    <i class="fas fa-exclamation-circle"></i> @errorMessage
                </div>
            }

            <!--Create Account button-->
            <button type="submit" class="signup-btn">Create Account</button>

            <!--Sign In link-->
            <div class="signup-login-link">
                Already have an account? <a href="/">Sign In</a>
            </div>
        </EditForm>
    </div>
</div>

<!--CreateAccount Logic-->
@code {
    // Initialize new user model
    private User newUser = new User();

    // Store the input validation error message
    private string errorMessage = "";

    // Confirm Password field
    private string confirmPassword = "";

    // Major and Minor options
    private readonly string[] MajorOptions = new[]
    {
        "Computer Science",
        "Data Science",
        "Other"
    };

    private readonly string[] MinorOptions = new[]
    {
        "Computer Science",
        "Applied Computer Science",
        "Other"

    };

    // Handle the account creation process
    private async Task HandleCreateAccount()
    {
        // Reset error message
        errorMessage = "";

        // Input validation here...
        if (string.IsNullOrEmpty(newUser.FName) || newUser.FName.Length > 45)
        {
            errorMessage = "Please enter a valid First Name (max 45 chars).";
            return;
        }
        if (string.IsNullOrEmpty(newUser.LName) || newUser.LName.Length > 45)
        {
            errorMessage = "Please enter a valid Last Name (max 45 chars).";
            return;
        }
        if (string.IsNullOrEmpty(newUser.CwuEmail) || !newUser.CwuEmail.ToLower().EndsWith("@cwu.edu") || newUser.CwuEmail.Length > 100)
        {
            errorMessage = "You must use a valid CWU email ending in @cwu.edu.";
            return;
        }
        if (string.IsNullOrEmpty(newUser.Major) || newUser.Major.Length > 45)
        {
            errorMessage = "You must select a valid Major from the major list.";
            return;
        }
        if (newUser.GraduationDate < 2026 || newUser.GraduationDate > 2030)
        {
            errorMessage = "Please enter a realistic graduation year.";
            return;
        }

        var hasUpper = new Regex(@"[A-Z]+");
        var hasSpecial = new Regex(@"[!@#$%^&*()_+=\[{\]};:<>|./?,-]+");

        if (string.IsNullOrEmpty(newUser.Password) || newUser.Password.Length < 7)
        {
            errorMessage = "Password must be at least 7 characters long.";
            return;
        }
        else if (!hasUpper.IsMatch(newUser.Password))
        {
            errorMessage = "Password must contain at least one capital letter.";
            return;
        }
        else if (!hasSpecial.IsMatch(newUser.Password))
        {
            errorMessage = "Password must contain at least one special character.";
            return;
        }

        if (newUser.Password != confirmPassword)
        {
            errorMessage = "Passwords do not match. Please try again.";
            return;
        }

        // Save to DB here...
        try
        {
            // Check if email already taken
            bool isTaken = await Db.IsEmailRegisteredAsync(newUser.CwuEmail);

            if (isTaken)
            {
                errorMessage = "This email is already registered. Please sign in or use a different email.";
                return;
            }

            // Add user to the database
            await Db.CreateUserAsync(newUser);

            // Redirect to Sign In page upon successful account creation
            NavManager.NavigateTo("/");
        }
        catch (Exception)
        {
            errorMessage = "An error occurred while creating your account. Please try again later.";
            return;
        }
    }
}

<!--Set Graduation Date to 2026 on component start-->
@code {
    protected override void OnInitialized()
    {
        newUser.GraduationDate = 2026;
    }
}