@page "/dashboard/quiz/{instanceId}"
@using CSLLMCapstone.Services
@using CSLLMCapstone.Models
@rendermode InteractiveServer
@inject DbService Db
@inject LLMService Llm
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<PageTitle>CS Study Cat - Quiz Mode</PageTitle>

<div class="dashboard-body">
    <!--Sidebar component-->
    @if (user != null)
    {
        <Sidebar FName="@(user.FName ?? "")" LName="@(user.LName ?? "")" />
    }
    else
    {
        <!--Pass Study Cat if user not found-->
        <Sidebar FName="Study" LName="Cat" />
    }
    
    <!--Main Content-->
    <div class="main-content">
        <!--Top Bar-->
        <div class="top-bar">
            <label for="sidebar-toggle" class="mobile-menu-btn">
                <i class="fas fa-bars"></i>
            </label>

            <div class="page-title">
                <h2><i class="fas fa-question-circle"></i> Quiz Mode</h2>
                @if (!string.IsNullOrEmpty(InstanceId))
                {
                    <span class="instance-id-badge">Instance: @InstanceId</span>
                }
            </div>
            
            <a href="/dashboard" class="close-modal">&times;</a>
        </div>

        <!--Dynamic Quiz Mode-->
        <div class="study-session-body">
            <div class="quiz-container">
                @if (quiz != null && quiz.Any())
                {
                    // Grab the current row
                    var currentQuestion = quiz[currentIndex];
                    <!--Quiz Header-->
                    <div class="quiz-header">
                        <div class="quiz-title">
                            @if (instance != null)
                            {
                                <span>CS @instance.CourseId @instance.CourseTitle</span>
                            }
                            else
                            {
                                <span>Loading Course Details...</span>
                            }
                        </div>
                        <div class="quiz-progress">Question @(currentIndex + 1) of @quiz.Count</div>
                    </div>

                    <!--Quiz Main Section-->
                    <div class="quiz-content">
                        <div class="quiz-question-section">
                            <h4>@currentQuestion[0]:</h4>
                            <p>@currentQuestion[1]</p>

                            <div class="quiz-options">
                                @for (int i = 2; i <= 5; i++) // Options are at indices 2, 3, 4, 5
                                {
                                    int optionIdx = i;
                                    <div class="quiz-option @(selectOptionIndex == optionIdx ? "active" : "")" @onclick="() => SelectOption(optionIdx)">
                                        <div class="quiz-option-letter">@((char)('A' + i - 2))</div>
                                        <div class="quiz-option-text">@currentQuestion[optionIdx]</div>
                                    </div>
                                }
                            </div>
                        </div>

                        @if (selectOptionIndex != null)
                        {
                            <div class="quiz-answer-section animate-popup">
                                <h5>Correct answer: @currentQuestion[6]</h5>
                                <p class="quiz-answer-text">Explanation: @currentQuestion[7]</p>
                                <p>You selected: @currentQuestion[selectOptionIndex.Value]</p>
                            </div>
                        }

                        <div class="quiz-controls" style="margin-top: 20px; display: flex; gap: 10px; justify-content: center;">
                            <button class="flashcard-nav-button" @onclick="PreviousQuestion" disabled="@(currentIndex == 0)">
                                <i class="fas fa-chevron-left"></i>
                            </button>
                            <button class="flashcard-nav-button" @onclick="NextQuestion" disabled="@(currentIndex == quiz.Count - 1)">
                                <i class="fas fa-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!--Footer-->
        <div class="footer">
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? InstanceId { get; set; }

    // delcare instance so HTML can access course info for quiz header
    private Instance? instance;

    private int currentIndex = 0;
    private int? selectOptionIndex = null;
    List<List<string>> quiz = new List<List<string>>();

    protected override async Task OnInitializedAsync()
    {
        // Load instance data here if needed
        if (!string.IsNullOrEmpty(InstanceId))
        {
            // get the instance from instance id
            instance = await Db.GetInstanceByIdAsync(InstanceId);

            if(instance != null)
            {
                // call llm service to generate quiz content based on instance data
                quiz = Llm.GenerateQuizDataList(instance.Data);
            }
        }
    }

    private void SelectOption(int index)
    {
		selectOptionIndex = index;
    }

    private void NextQuestion()
    {
        if(currentIndex < quiz.Count - 1)
        {
            currentIndex++;
            selectOptionIndex = null; // reset selected option for next question
        }
	}

    private void PreviousQuestion()
    {
        if(currentIndex > 0)
        {
            currentIndex--;
            selectOptionIndex = null; // reset selected option for previous question
        }
	}
}   

@code {
    // User details - to be fetched from DB
    private User? user;

    // Checking if user is authenticated
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 1. Check local storage for the UserID
            var userId = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "UserId");

            if (string.IsNullOrEmpty(userId))
            {
                // 2. If no user found, boot them to login
                NavManager.NavigateTo("/");
            }
            else
            {
                // 3. User is valid, fetch the user details and show the UI
                user = await Db.GetUserByIdAsync(int.Parse(userId));
                StateHasChanged(); // Force a re-render now that we have data
            }
        }
    }
}