@page "/dashboard/quiz/{instanceId}"
@using CSLLMCapstone.Services
@using CSLLMCapstone.Models
@rendermode InteractiveServer
@inject DbService Db
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<PageTitle>CS Study Cat - Quiz Mode</PageTitle>

<div class="dashboard-body">
    <!--Sidebar component-->
    @if (user != null)
    {
        <Sidebar FName="@(user.FName ?? "")" LName="@(user.LName ?? "")" />
    }
    else
    {
        <!--Pass Study Cat if user not found-->
        <Sidebar FName="Study" LName="Cat" />
    }
    
    <!--Main Content-->
    <div class="main-content">
        <!--Top Bar-->
        <div class="top-bar">
            <label for="sidebar-toggle" class="mobile-menu-btn">
                <i class="fas fa-bars"></i>
            </label>

            <div class="page-title">
                <h2><i class="fas fa-question-circle"></i> Quiz Mode</h2>
                @if (!string.IsNullOrEmpty(InstanceId))
                {
                    <span class="instance-id-badge">Instance: @InstanceId</span>
                }
            </div>
            
            <a href="/dashboard" class="close-modal">&times;</a>
        </div>

        <!--Quiz Content-->
        <div class="study-session-body">
            <div class="quiz-container">
                <div class="quiz-header">
                    <div class="quiz-title">Lorem Ipsum Quiz</div>
                    <div class="quiz-progress">Question 5 of 12</div>
                </div>

                <!--HARDCODED BRUHHHHH-->
                <div class="quiz-content">
                    <div class="quiz-question-section">
                        <h4>Question 5:</h4>
                        <p>Lorem ipsum dolor sit amet consectetur adipiscing elit?</p>

                        <div class="quiz-options">
                            <div class="quiz-option">
                                <div class="quiz-option-letter">A</div>
                                <div class="quiz-option-text">Quisque faucibus ex sapien vitae pellentesque</div>
                            </div>
                            <div class="quiz-option">
                                <div class="quiz-option-letter">B</div>
                                <div class="quiz-option-text">In id cursus mi pretium tellus duis convallis</div>
                            </div>
                            <div class="quiz-option">
                                <div class="quiz-option-letter">C</div>
                                <div class="quiz-option-text">Tempus leo eu aenean sed diam urna tempor</div>
                            </div>
                            <div class="quiz-option">
                                <div class="quiz-option-letter">D</div>
                                <div class="quiz-option-text">Pulvinar vivamus fringilla lacus nec metus</div>
                            </div>
                        </div>
                    </div>

                    <div class="quiz-answer-section">
                        <h5>Correct answer: B</h5>
                        <p class="quiz-answer-text">In id cursus mi pretium tellus duis convallis</p>
                        <p>Lorem ipsum dolor sit amet consectetur adipiscing elit. Quisque faucibus ex sapien vitae pellentesque sem placerat. In id cursus mi pretium tellus duis convallis. Tempus leo eu aenean sed diam urna tempor. Pulvinar vivamus fringilla lacus nec metus bibendum egestas.</p>
                    </div>
                </div>
            </div>
        </div>

        <!--Footer-->
        <div class="footer">
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? InstanceId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Load instance data here if needed
        if (!string.IsNullOrEmpty(InstanceId))
        {
            // TODO: Load quiz data based on InstanceId from database
            Console.WriteLine($"Quiz instance loaded: {InstanceId}");
        }
    }
}   

@code {
    // User details - to be fetched from DB
    private User? user;

    // Checking if user is authenticated
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 1. Check local storage for the UserID
            var userId = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "UserId");

            if (string.IsNullOrEmpty(userId))
            {
                // 2. If no user found, boot them to login
                NavManager.NavigateTo("/");
            }
            else
            {
                // 3. User is valid, fetch the user details and show the UI
                user = await Db.GetUserByIdAsync(int.Parse(userId));
                StateHasChanged(); // Force a re-render now that we have data
            }
        }
    }
}